# ============================================================
# Kint 環境変数設定サンプル
# このファイルをコピーして .env を作成してください。
#   cp .env.example .env
# ============================================================

# ------ アプリケーション基本設定 ------

# JWT 署名に使用するシークレットキー（本番では必ず変更すること）
SECRET_KEY=change-me-in-production

# デバッグモード（本番では false に設定すること）
DEBUG=false

# アプリケーションの公開 URL（確認メール内のリンク生成に使用）
APP_BASE_URL=http://localhost:8000

# ------ データベース設定 ------

# SQLite データベースファイルのパス
DATABASE_URL=sqlite+aiosqlite:///./kint.db

# ------ メール確認設定 ------

# 確認メールトークンの有効期限（時間）
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# ------ Gmail API 設定 (BE-10) ------
# Google Cloud Console で OAuth 2.0 クライアント ID を作成して取得する。
# 参照: https://console.cloud.google.com/apis/credentials

# === 推奨: リフレッシュトークン直接指定方式 ===
# GMAIL_CLIENT_ID / GMAIL_CLIENT_SECRET / GMAIL_REFRESH_TOKEN の 3 つを設定すると
# ファイル不要でサーバーサイドのみで Gmail 認証が完了する。

# Gmail 送信元アカウントのメールアドレス
# GMAIL_USER=yourname@gmail.com

# OAuth 2.0 クライアント ID（Google Cloud Console > 認証情報 > OAuth クライアント ID）
# GMAIL_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# OAuth 2.0 クライアントシークレット
# GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# OAuth 2.0 リフレッシュトークン（Google OAuth2 Playground などで取得）
# GMAIL_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxx

# === フォールバック: ファイル方式（ローカル開発用） ===
# 上記 3 変数が未設定の場合に使用される。初回起動時にブラウザで認可フローが起動する。

# OAuth クライアント認証情報 JSON のパス（初回認可時に必要）
# GMAIL_OAUTH_CREDENTIALS_FILE=credentials.json

# OAuth トークンの保存先ファイルパス（初回認可後に自動生成される）
GMAIL_TOKEN_FILE=gmail_token.json

# 送信元アドレス（GMAIL_USER 未設定時のフォールバック）
# GMAIL_SENDER_EMAIL=noreply@your-domain.com

# ------ Google Calendar API 設定 ------
# シフトカレンダー連携に使用するサービスアカウント認証情報 JSON のパス
# GOOGLE_CALENDAR_CREDENTIALS_FILE=service_account.json

# ------ Google Identity Services (GSI) 設定 ------
# Google Cloud Console > OAuth 2.0 クライアント ID (Web アプリケーション)
GOOGLE_CLIENT_ID=

# 管理者として自動登録を許可するパスワード（初回ログイン時のみ有効）
# 空の場合は管理者として登録できない（全員が従業員として登録される）
ADMIN_PASSWORD=